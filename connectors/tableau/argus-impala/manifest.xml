<?xml version='1.0' encoding='utf-8' ?>

<!--
  Argus ODBC — Tableau connector for the Impala backend.

  Impala speaks HiveServer2 too, so this mirrors argus-hive; the differences are
  the default port (21050) and the dialect. Kudu tables are reached through
  Impala, which is why BACKEND=kudu is deprecated.

  Each customization states a fact about the driver or about Impala. If one has
  to paper over what SQLGetInfo reports, the bug is in the driver, not here.
-->
<connector-plugin class='argus_impala'
                  superclass='odbc'
                  plugin-version='0.1.0'
                  name='Argus (Impala)'
                  version='18.1'
                  min-version-tableau='2020.4'>

  <vendor-information>
    <company name="Varga Foundation"/>
    <support-link url="https://github.com/VargaFoundation/argus/issues"/>
    <driver-download-link url="https://github.com/VargaFoundation/argus/releases"/>
  </vendor-information>

  <connection-customization class="argus_impala" enabled="true" version="10.0">
    <vendor name="Varga Foundation"/>
    <driver name="Argus ODBC Driver"/>
    <customizations>
      <!-- Impala spells top-N as LIMIT. -->
      <customization name="CAP_QUERY_TOP_N" value="yes"/>
      <customization name="CAP_QUERY_TOPSTYLE_LIMIT" value="yes"/>
      <customization name="CAP_QUERY_TOPSTYLE_TOP" value="no"/>
      <customization name="CAP_QUERY_TOPSTYLE_ROWNUM" value="no"/>
      <customization name="CAP_QUERY_SUBQUERIES" value="yes"/>
      <customization name="CAP_QUERY_GROUP_BY_DEGREE" value="yes"/>
      <customization name="CAP_QUERY_WHERE_FALSE_METADATA" value="yes"/>
      <customization name="CAP_QUERY_TOP_0_METADATA" value="yes"/>

      <customization name="CAP_CREATE_TEMP_TABLES" value="no"/>
      <customization name="CAP_SELECT_INTO" value="no"/>
      <customization name="CAP_SELECT_TOP_INTO" value="no"/>

      <!-- SQL_TXN_CAPABLE = SQL_TC_NONE; SQLEndTran is a no-op. -->
      <customization name="CAP_ODBC_TRANSACTIONS_SUPPRESS_AUTO_COMMIT" value="yes"/>
      <customization name="CAP_ODBC_TRANSACTIONS_SUPPRESS_EXPLICIT_COMMIT" value="yes"/>

      <!-- SQLPrepare is client-side on every Argus backend. -->
      <customization name="CAP_ODBC_METADATA_SUPPRESS_PREPARED_QUERY" value="yes"/>
      <customization name="CAP_ODBC_CONNECTION_STATE_VERIFY_PROBE_PREPARED_QUERY" value="no"/>

      <!-- The Impala backend has no get_statistics hook (only Trino does), and
           no backend has a foreign-keys hook: both would return an empty result
           set at the cost of a round trip. SQLPrimaryKeys is implemented. -->
      <customization name="CAP_ODBC_METADATA_SUPPRESS_SQLSTATISTICS_API" value="yes"/>
      <customization name="CAP_ODBC_METADATA_SUPPRESS_SQLFOREIGNKEYS_API" value="yes"/>

      <customization name="CAP_ODBC_SUPPRESS_INFO_SCHEMA_TABLES" value="yes"/>
      <customization name="CAP_ODBC_SUPPRESS_INFO_SCHEMA_STORED_PROCS" value="yes"/>
    </customizations>
  </connection-customization>

  <connection-fields file='connectionFields.xml'/>
  <connection-metadata file='connectionMetadata.xml'/>
  <connection-resolver file='connectionResolver.tdr'/>
  <dialect file='dialect.tdd'/>
</connector-plugin>
