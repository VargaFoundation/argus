<?xml version="1.0"?>
<configuration>
  <property>
    <name>hadoop.security.authentication</name>
    <value>kerberos</value>
  </property>
  <!-- Authentication only: service-level authorization triggers an HDFS
       /tmp/hive permission check that crash-loops HS2 in this local setup. -->
  <property>
    <name>hadoop.security.authorization</name>
    <value>false</value>
  </property>
</configuration>
